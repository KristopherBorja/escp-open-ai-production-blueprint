{
  "name": "escp-open-ai-production-blueprint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "verify:container": "node scripts/verify-container.mjs",
    "verify:model": "node scripts/verify-model-manifest.mjs",
    "verify:space": "node scripts/verify-static-space-artifact.mjs",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:scripts && npm run build && npm run verify:space && npm run verify:model"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "onnxruntime-web": "1.26.0-dev.20260416-b7804b056c"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
